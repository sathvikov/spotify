from airflow import DAG
from airflow.providers.standard.operators.python import PythonOperator
from datetime import datetime, timedelta

import requests
import pandas as pd


default_args = {
    "owner": "Rushi",
    "depends_on_past": False,
    "start_date": datetime(2026, 3, 6),
}

dag = DAG(
    dag_id="read_spotify_json",
    default_args=default_args,
    schedule=timedelta(days=1),
    catchup=False,
)


def read_json():

    url = "https://raw.githubusercontent.com/rushi4git/spotify-playlist-data/refs/heads/main/spotify_playlist.json"

    response = requests.get(url)

    data = response.json()

    df = pd.DataFrame(data["tracks"])

    print("Data from JSON file:")
    print(df.head())


read_task = PythonOperator(
    task_id="read_json_file",
    python_callable=read_json,
    dag=dag,
)

read_task
